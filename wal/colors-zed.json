{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d151f90",
                "editor.background": "#0d151f90",
                "editor.foreground": "#c2c4c7",
                "text": "#c2c4c7",
                "text.muted": "#c2c4c770",
                "text.ignored": "#c2c4c740",
                "text.placeholder": "#c2c4c750",
                "ignored": "#c2c4c730",
                "element.hover": "#c2c4c730",
                "ghost_element.hover": "#54687e30",
                "ghost_element.selected": "#54687e30",
                "ghost_element.active": "#54687e60",
                "border": "#0d151f",
                "editor.highlighted_line.background": "#54687e10",
                "editor.active_line.background": "#54687e10",
                "panel.background": "#0d151f90",
                "title_bar.background": "#0d151f90",
                "title_bar.inactive_background": "#0d151f90",
                "status_bar.background": "#0d151f90",
                "drop_target.background": "#0d151f90",
                "elevated_surface.background": "#0d151f",
                "toolbar.background": "#0d151f90",
                "tab_bar.background": "#0d151f90",
                "tab.inactive_background": "#0d151f90",
                "tab.active_background": "#54687e30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d151f",
                "scrollbar.thumb.background": "#54687e",
                "editor.gutter.background": "#0d151f90",
                "terminal.background": "#0d151f10",
                "terminal.foreground": "#c2c4c7",
                "terminal.dim_foreground": "#c2c4c7",
                "terminal.bright_foreground": "#c2c4c7",
                "terminal.ansi.black": "#0d151f",
                "terminal.ansi.red": "#54687e",
                "terminal.ansi.green": "#68778b",
                "terminal.ansi.yellow": "#7b8799",
                "terminal.ansi.blue": "#8a94a0",
                "terminal.ansi.magenta": "#8b98a8",
                "terminal.ansi.cyan": "#9299a5",
                "terminal.ansi.white": "#90949b",
                "terminal.ansi.bright_black": "#5c6571",
                "terminal.ansi.bright_red": "#718BA8",
                "terminal.ansi.bright_green": "#8B9FBA",
                "terminal.ansi.bright_yellow": "#A5B5CC",
                "terminal.ansi.bright_blue": "#B9C6D6",
                "terminal.ansi.bright_magenta": "#BACBE1",
                "terminal.ansi.bright_cyan": "#C3CCDD",
                "terminal.ansi.bright_white": "#c2c4c7",
                "modified": "#54687e",
                "syntax": {
                    "attribute": {
                        "color": "#54687e"
                    },
                    "boolean": {
                      "color": "#68778b"
                    },
                    "comment": {
                      "color": "#5c6571"
                    },
                    "comment.doc": {
                      "color": "#5c6571"
                    },
                    "constant": {
                      "color": "#8B9FBA"
                    },
                    "function": {
                      "color": "#C3CCDD"
                    },
                    "keyword": {
                      "color": "#8a94a0"
                    },
                    "number": {
                      "color": "#8b98a8"
                    },
                    "operator": {
                      "color": "#8a94a0"
                    },
                    "string": {
                      "color": "#54687e"
                    },
                    "variable": {
                      "color": "#68778b"
                    }
                },
                "players": [
                  {
                    "cursor": "#54687e",
                    "background": "#0d151f",
                    "selection": "#54687e30"
                  }
                ]
            }
        }
    ]
}
